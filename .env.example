NEBIUS_API_KEY=XXX

# Airflow DAG defaults. These may also be overridden from the Airflow trigger form.
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=swe-bench-agent-evals

# Optional long-term artifact storage. The current DAG writes local runs/<run-id>/
# and records the path in MLflow; sync this directory to the bucket below if used.
S3_ARTIFACT_URI=s3://your-bucket/swe-bench-runs/
