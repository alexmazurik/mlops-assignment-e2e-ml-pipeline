NEBIUS_API_KEY=XXX

# DockerOperator execution.
# Defaults are clone-friendly: docker-compose.yaml uses ${PWD} as HOST_PROJECT_ROOT
# and builds EXECUTION_IMAGE locally. Override these only for unusual Docker setups.
# EXECUTION_IMAGE=swe-bench-agent-airflow:latest
# HOST_PROJECT_ROOT=/absolute/path/to/this/checkout
# HOST_DOCKER_SOCKET=/var/run/docker_socket/docker.sock

# Airflow DAG defaults. These may also be overridden from the Airflow trigger form.
MLFLOW_TRACKING_URI=http://localhost:5018
MLFLOW_EXPERIMENT_NAME=swe-bench-agent-evals

# Optional local S3-compatible artifact storage via MinIO.
S3_ARTIFACT_URI=s3://mlops-runs/swe-bench-runs/
AWS_ENDPOINT_URL_S3=http://localhost:9000
MINIO_BROWSER_URI=http://localhost:9001
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
